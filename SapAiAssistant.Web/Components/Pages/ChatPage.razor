@page "/"
@page "/chat"
@rendermode InteractiveServer
@using SapAiAssistant.Domain.Entities
@using SapAiAssistant.Web.Services
@using SapAiAssistant.Web.Components.Chat
@inject ChatState State
@implements IDisposable

<PageTitle>SAP B1 AI Assistant</PageTitle>

<div class="chat-shell">

    <aside class="chat-sidebar">
        <div class="sidebar-header">
            <span class="sidebar-title">SAP AI Assistant</span>
        </div>

        <div class="new-chat-buttons">
            <button class="btn-new-chat" @onclick="() => State.StartNewConversation(AssistantMode.BusinessUser)">
                + Business Query
            </button>
            <button class="btn-new-chat btn-dev" @onclick="() => State.StartNewConversation(AssistantMode.Developer)">
                + Developer Mode
            </button>
        </div>

        <ConversationList
            Conversations="State.Conversations"
            ActiveSessionId="State.ActiveSessionId"
            OnSelect="OnSelectConversation" />
    </aside>

    <section class="chat-main">
        @if (!string.IsNullOrEmpty(State.ErrorMessage))
        {
            <div class="error-banner">
                <span>@State.ErrorMessage</span>
                <button @onclick="DismissError">✕</button>
            </div>
        }

        <div class="chat-mode-badge @(State.ActiveMode == AssistantMode.Developer ? "badge-dev" : "badge-biz")">
            @(State.ActiveMode == AssistantMode.Developer ? "Developer Mode" : "Business User Mode")
        </div>

        <MessageThread Messages="State.Messages" IsLoading="State.IsLoading" />

        @if (!State.IsLoading && State.Messages.Count == 0)
        {
            <div class="empty-state">
                <div class="empty-state-icon">🤖</div>
                <h2 class="empty-state-title">SAP AI Assistant</h2>
                <p class="empty-state-subtitle">Ask anything about your SAP Business One data.</p>
                <div class="empty-state-prompts">
                    <button class="prompt-chip" @onclick='() => OnSendMessage("What is SAP Business One?")'>What is SAP Business One?</button>
                    <button class="prompt-chip" @onclick='() => OnSendMessage("Show me customer C001 details")'>Show me customer C001 details</button>
                    <button class="prompt-chip" @onclick='() => OnSendMessage("Look up invoice 200")'>Look up invoice 200</button>
                    <button class="prompt-chip" @onclick='() => OnSendMessage("How do I add a new business partner?")'>How do I add a new business partner?</button>
                </div>
            </div>
        }

        <ChatInput OnSend="OnSendMessage" IsDisabled="State.IsLoading" />
    </section>

</div>

@code {
    protected override async Task OnInitializedAsync()
    {
        State.OnChange += StateHasChanged;
        await State.LoadConversationsAsync();
    }

    private async Task OnSelectConversation(Guid sessionId)
        => await State.SelectConversationAsync(sessionId);

    private async Task OnSendMessage(string text)
        => await State.SendMessageAsync(text);

    private void DismissError()
    {
        // Re-expose via ChatState if needed; for now trigger a re-render
        StateHasChanged();
    }

    public void Dispose() => State.OnChange -= StateHasChanged;
}
